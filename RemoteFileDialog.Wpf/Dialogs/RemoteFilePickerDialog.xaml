<Window x:Class="RemoteFileDialog.Wpf.Dialogs.RemoteFilePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:RemoteFileDialog.Wpf.ViewModels"
        Title="Select Remote File(s)"
        Width="900"
        Height="620"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type viewModels:RemoteTreeNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Name}" />
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Status -->
        <Border Grid.Row="0" Background="White" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="12" Height="12" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Browser.IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="Green"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <TextBlock Text="{Binding Browser.StatusMessage}" FontWeight="SemiBold"/>

                    <Button Content="Reconnect"
                            Margin="16,0,0,0"
                            Height="28"
                            MinWidth="95"
                            Command="{Binding Browser.ReconnectCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Browser.CanReconnect}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <DockPanel Grid.Row="1" Margin="0,8,0,0">
                    <TextBlock Text="{Binding Browser.ConnectionDisplayName}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Browser.CurrentPath, StringFormat=Current Path: {0}}"
                               HorizontalAlignment="Right"/>
                </DockPanel>
            </Grid>
        </Border>

        <!-- Browser -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#D0D0D0" BorderThickness="1">
                <DockPanel>
                    <TextBlock Text="Folder Tree" FontWeight="SemiBold" Padding="10" Background="#EEEEEE" DockPanel.Dock="Top"/>

                    <TreeView ItemsSource="{Binding Browser.TreeNodes}"
                              BorderThickness="0"
                              SelectedItemChanged="FolderTree_SelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent"/>

            <Border Grid.Column="2" Background="White" BorderBrush="#D0D0D0" BorderThickness="1">
                <DockPanel>
                    <TextBlock Text="Files in Selected Path" FontWeight="SemiBold" Padding="10" Background="#EEEEEE" DockPanel.Dock="Top"/>

                    <ListView ItemsSource="{Binding Browser.Items}"
                              MouseDoubleClick="FileList_MouseDoubleClick"
                              BorderThickness="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="" Width="40">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Command="{Binding DataContext.ToggleFileSelectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}"
                                                      HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Name" Width="320">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📄" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Name}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Size" Width="100" DisplayMemberBinding="{Binding Size}"/>
                                <GridViewColumn Header="Modified" Width="160" DisplayMemberBinding="{Binding ModifiedDate}"/>
                            </GridView>
                        </ListView.View>

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFile}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Selected Files -->
        <Border Grid.Row="2" Background="White" BorderBrush="#D0D0D0" BorderThickness="0,1,0,1" Padding="12">
            <DockPanel>
                <TextBlock Text="{Binding SelectedFilePaths.Count, StringFormat=Selected Files: {0}}"
                           FontWeight="SemiBold"
                           DockPanel.Dock="Top"/>

                <ListBox ItemsSource="{Binding SelectedFilePaths}" BorderThickness="0"/>
            </DockPanel>
        </Border>

        <!-- Buttons -->
        <Border Grid.Row="3" Background="White" Padding="12">
            <DockPanel LastChildFill="False">
                <Button Content="Refresh"
                        Style="{StaticResource PrimaryButtonStyle}"
                        DockPanel.Dock="Left"
                        Command="{Binding Browser.RefreshCommand}"/>

                <Button Content="Select File(s)"
                        Style="{StaticResource PrimaryButtonStyle}"
                        DockPanel.Dock="Right"
                        IsDefault="True"
                        Command="{Binding ConfirmSelectionCommand}"
                        Click="SelectButton_Click"/>

                <Button Content="Cancel"
                        Style="{StaticResource PrimaryButtonStyle}"
                        DockPanel.Dock="Right"
                        IsCancel="True"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
