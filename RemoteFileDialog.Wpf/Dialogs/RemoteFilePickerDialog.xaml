<Window x:Class="RemoteFileDialog.Wpf.Dialogs.RemoteFilePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:RemoteFileDialog.Wpf.ViewModels"
        Title="Select Remote File(s)"
        Width="900"
        Height="620"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,4"/>
        </Style>

        <Style x:Key="SelectButtonStyle"
       TargetType="Button">

            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="BorderBrush" Value="#256628"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="2">

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border"
                                Property="Background"
                                Value="#388E3C"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border"
                                Property="Background"
                                Value="#1F5A22"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border"
                                Property="Background"
                                Value="#BDBDBD"/>

                                <Setter Property="Foreground"
                                Value="#F5F5F5"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type viewModels:RemoteTreeNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Name}" />
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Status -->
        <Border Grid.Row="0" Background="White" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="12" Height="12" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Browser.IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="Green"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <TextBlock Text="{Binding Browser.StatusMessage}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Loading..."
                               Margin="12,0,0,0"
                               Foreground="#666666"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Browser.IsBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ProgressBar Width="90"
                                 Height="4"
                                 Margin="10,0,0,0"
                                 IsIndeterminate="True"
                                 VerticalAlignment="Center">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Browser.IsBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    
                    <Button Content="Reconnect"
                            Margin="16,0,0,0"
                            Height="28"
                            MinWidth="95"
                            Command="{Binding Browser.ReconnectCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Browser.CanReconnect}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <DockPanel Grid.Row="1" Margin="0,8,0,0">
                    <TextBlock Text="{Binding Browser.ConnectionDisplayName}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Browser.CurrentPath, StringFormat=Current Path: {0}}"
                               HorizontalAlignment="Right"/>
                </DockPanel>
            </Grid>
        </Border>
        
        <!-- Browser -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Folder Tree -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock Text="Folder Tree"
                       FontWeight="SemiBold"
                       Padding="10"
                       Background="#EEEEEE"
                       DockPanel.Dock="Top"/>

                    <TreeView ItemsSource="{Binding Browser.TreeNodes}"
                      BorderThickness="0"
                      SelectedItemChanged="FolderTree_SelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                  Width="8"
                  HorizontalAlignment="Stretch"
                  Background="Transparent"/>

            <!-- Right File List -->
            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1">
                <DockPanel>

                    <!-- Header -->
                    <TextBlock Text="Files in Selected Path"
                       FontWeight="SemiBold"
                       Padding="10"
                       Background="#EEEEEE"
                       DockPanel.Dock="Top"/>                 

                    <!-- Files -->
                    <ListView ItemsSource="{Binding Browser.Items}"
                      MouseDoubleClick="FileList_MouseDoubleClick"
                      BorderThickness="0">

                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="40">
                                    <GridViewColumn.Header>
                                        <CheckBox IsChecked="{Binding AreAllFilesSelected, Mode=TwoWay}"
                                                  Command="{Binding ToggleSelectAllFilesCommand}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </GridViewColumn.Header>

                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Command="{Binding DataContext.ToggleFileSelectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Name" Width="330">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">

                                                <Path Width="14"
                                                      Height="16"
                                                      Margin="0,0,8,0"
                                                      Stretch="Uniform"
                                                      Fill="#4A6FA5"
                                                      Data="M3,1 L10,1 L14,5 L14,16 L3,16 Z M10,1 L10,5 L14,5"/>

                                                <TextBlock Text="{Binding Name}"
                                                    VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Size"
                                        Width="100"
                                        DisplayMemberBinding="{Binding Size}"/>

                                <GridViewColumn Header="Modified"
                                        Width="170"
                                        DisplayMemberBinding="{Binding ModifiedDate}"/>
                            </GridView>
                        </ListView.View>

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="2"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFile}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>

                </DockPanel>
            </Border>
        </Grid>

        <!-- Selected Files -->
        <Border Grid.Row="2" Background="White" BorderBrush="#D0D0D0" BorderThickness="0,1,0,1" Padding="12">
            <DockPanel>
                <TextBlock Text="{Binding SelectedFilePaths.Count, StringFormat=Selected Files: {0}}"
                           FontWeight="SemiBold"
                           DockPanel.Dock="Top"/>

                <ListBox ItemsSource="{Binding SelectedFilePaths}" BorderThickness="0"/>
            </DockPanel>
        </Border>

        <!-- Buttons -->
        <Border Grid.Row="3" Background="White" Padding="12">
            <DockPanel LastChildFill="False">
                <Button Content="Refresh"
                        Style="{StaticResource PrimaryButtonStyle}"
                        DockPanel.Dock="Left"
                        Command="{Binding Browser.RefreshCommand}"/>

                <Button Content="Select File(s)"
                        Style="{StaticResource SelectButtonStyle}"
                        DockPanel.Dock="Right"
                        IsDefault="True"
                        Command="{Binding ConfirmSelectionCommand}"
                        Click="SelectButton_Click"/>

                <Button Content="Cancel"
                        Style="{StaticResource PrimaryButtonStyle}"
                        DockPanel.Dock="Right"
                        IsCancel="True"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
