<Window x:Class="RemoteFileDialog.Wpf.Dialogs.RemoteFolderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:RemoteFileDialog.Wpf.ViewModels"
        Title="Select Remote Folder"
        Width="900"
        Height="600"
        MinWidth="760"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,4"/>
        </Style>

        <Style x:Key="SelectButtonStyle"
       TargetType="Button">

            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="BorderBrush" Value="#256628"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="2">

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border"
                                Property="Background"
                                Value="#388E3C"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border"
                                Property="Background"
                                Value="#1F5A22"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border"
                                Property="Background"
                                Value="#BDBDBD"/>

                                <Setter Property="Foreground"
                                Value="#F5F5F5"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type viewModels:RemoteTreeNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Name}" />
        </HierarchicalDataTemplate>

    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Status Area -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#D0D0D0"
                BorderThickness="0,0,0,1"
                Padding="12">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="12"
                             Height="12"
                             Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Browser.IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="Green"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <TextBlock Text="{Binding Browser.StatusMessage}"
           FontWeight="SemiBold"
           VerticalAlignment="Center"/>

                    <TextBlock Text="Loading..."
                               Margin="12,0,0,0"
                               Foreground="#666666"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Browser.IsBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ProgressBar Width="90"
                                 Height="4"
                                 Margin="10,0,0,0"
                                 IsIndeterminate="True"
                                 VerticalAlignment="Center">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Browser.IsBusy}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>

                    <Button Content="Reconnect"
                            Margin="16,0,0,0"
                            Height="28"
                            MinWidth="95"
                            Command="{Binding Browser.ReconnectCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Browser.CanReconnect}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <DockPanel Grid.Row="1"
                           Margin="0,8,0,0">
                    <TextBlock Text="{Binding Browser.ConnectionDisplayName}"
                               FontWeight="SemiBold"
                               DockPanel.Dock="Left"/>

                    <TextBlock Text="{Binding Browser.CurrentPath, StringFormat=Current Path: {0}}"
                               HorizontalAlignment="Right"/>
                </DockPanel>
            </Grid>
        </Border>
        
        <!-- Main Browser Area -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Tree -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock Text="Folder Tree"
                               FontWeight="SemiBold"
                               Padding="10"
                               Background="#EEEEEE"
                               DockPanel.Dock="Top"/>

                    <TreeView ItemsSource="{Binding Browser.TreeNodes}"
                              BorderThickness="0"
                              SelectedItemChanged="FolderTree_SelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"/>

            <!-- Right Folder List -->
            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock Text="Folders in Selected Path"
                               FontWeight="SemiBold"
                               Padding="10"
                               Background="#EEEEEE"
                               DockPanel.Dock="Top"/>

                    <ListView ItemsSource="{Binding Browser.Items}"
                              MouseDoubleClick="FolderList_MouseDoubleClick"
                              SelectionChanged="FolderList_SelectionChanged"
                              BorderThickness="0">

                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="320">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Path Width="14"
                                                      Height="12"
                                                      Margin="0,0,8,0"
                                                      Stretch="Uniform"
                                                      Fill="#D19A00"
                                                      Data="M2,4 L6,4 L7.5,6 L14,6 L14,14 L2,14 Z"/>
                                                <TextBlock Text="{Binding Name}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <GridViewColumn Header="Modified" Width="160"
                                                DisplayMemberBinding="{Binding ModifiedDateText}"/>
                            </GridView>
                        </ListView.View>

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Selected Folder -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#D0D0D0"
                BorderThickness="0,1,0,1"
                Padding="12">
            <TextBlock Text="{Binding SelectedFolderPath, StringFormat=Selected Folder: {0}, TargetNullValue=Selected Folder: -}"/>
        </Border>

        <!-- Bottom Buttons -->
        <!-- Bottom Buttons -->
        <Border Grid.Row="3"
        Background="White"
        Padding="12">
            <DockPanel LastChildFill="False">

                <Button Content="Refresh"
                Style="{StaticResource PrimaryButtonStyle}"
                DockPanel.Dock="Left"
                Command="{Binding Browser.RefreshCommand}"/>

                <Button Content="Select Folder"
                        Style="{StaticResource SelectButtonStyle}"
                        DockPanel.Dock="Right"
                        IsDefault="True"
                        Command="{Binding ConfirmSelectionCommand}"
                        Click="SelectButton_Click"/>

                <Button Content="Cancel"
                Style="{StaticResource PrimaryButtonStyle}"
                DockPanel.Dock="Right"
                IsCancel="True"/>

            </DockPanel>
        </Border>
    </Grid>
</Window>