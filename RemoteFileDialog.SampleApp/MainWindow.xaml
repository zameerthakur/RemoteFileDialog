<Window x:Class="RemoteFileDialog.SampleApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteFileDialog Test"
        Height="220"
        Width="420"
        WindowStartupLocation="CenterScreen">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

        <Button Content="Open Folder Dialog"
                Width="250"
                Height="40"
                Click="OpenFolderDialog_Click"/>

        <Button Content="Open File Dialog"
                Width="250"
                Height="40"
                Margin="0,12,0,0"
                Click="OpenFileDialog_Click"/>

    </StackPanel>
</Window>